    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\nconst totalSales = (Number(d.sales_interval_1) || 0) +\n                   (Number(d.sales_interval_2) || 0) +\n                   (Number(d.sales_interval_3) || 0);\n\nconst i1 = d.shift_type === 'AM' ? 'Open–11am' : '5pm–7pm';\nconst i2 = d.shift_type === 'AM' ? '11am–1pm' : '7pm–9pm';\nconst i3 = d.shift_type === 'AM' ? '1pm–Close' : '9pm–Close';\n\nconst systemPrompt = `You are a restaurant operations assistant helping a shift leader format their nightly logbook entry.\n\nTake the structured data and raw notes and produce a clean, consistent, professional logbook entry with the following sections: Performance Summary, Staffing, Service Notes, Incidents & Resolution, Action Items for Next Shift, Follow-ups for Management.\n\nBe concise. Use bullet points within sections. If sales are notably high or low, call it out. If the raw notes mention anything that should be escalated, flag it under Follow-ups. If a field was left blank (e.g., no incidents, no VIP guests), handle it gracefully. Do not invent information not present in the input.`;\n\nconst userPrompt = `Please format the following shift data into a professional logbook entry.\n\nSHIFT INFORMATION:\n- Date: ${d.date}\n- Shift Type: ${d.shift_type}\n\nSTAFFING:\n- Servers: ${d.servers}\n- Bartenders: ${d.bartenders}\n- Hosts: ${d.hosts}\n- Bussers: ${d.bussers}\n- Expo: ${d.expo}\n- Managers: ${d.managers}\n\nSALES BY INTERVAL:\n- ${i1}: $${Number(d.sales_interval_1 || 0).toLocaleString()}\n- ${i2}: $${Number(d.sales_interval_2 || 0).toLocaleString()}\n- ${i3}: $${Number(d.sales_interval_3 || 0).toLocaleString()}\n- Total: $${totalSales.toLocaleString()}\n\nSHIFT NARRATIVE (raw notes):\n${d.shift_narrative}\n\nINCIDENTS:\n${d.incidents || 'None reported.'}\n\nVIP / NOTABLE GUESTS:\n${d.vip_guests || 'None noted.'}`;\n\nreturn [{\n  json: {\n    ...d,\n    systemPrompt,\n    userPrompt,\n    staffingJson: JSON.stringify({\n      servers: d.servers,\n      bartenders: d.bartenders,\n      hosts: d.hosts,\n      bussers: d.bussers,\n      expo: d.expo,\n      managers: d.managers\n    }),\n    salesJson: JSON.stringify({\n      [i1]: Number(d.sales_interval_1),\n      [i2]: Number(d.sales_interval_2),\n      [i3]: Number(d.sales_interval_3),\n      total: totalSales\n    }),\n    totalSales\n  }\n}];"
      },
      "id": "63d4d97b-3854-4c7d-bbe7-6896a6f41780",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        448
      ]
