    {
      "parameters": {
        "jsCode": "const claudeJson = $input.first().json;\nconst formData = $('Build Prompt').first().json;\n\nconst aiText = claudeJson.content[0].text;\n\nconst extractSection = (text, label) => {\n  const regex = new RegExp(`#{1,3}\\\\s*${label}[\\\\s\\\\S]*?(?=#{1,3}|$)`, 'i');\n  const match = text.match(regex);\n  if (!match) return '';\n  return match[0].replace(/#{1,3}[^\\n]*\\n/, '').trim();\n};\n\nconst toSlack = (text) => text\n  .replace(/^#{1,3} (.+)$/gm, '*$1*')\n  .replace(/\\*\\*(.+?)\\*\\*/g, '*$1*')\n  .replace(/^---+$/gm, '─────────────')\n  .trim();\n\nconst toPlainText = (text) => text\n  .replace(/^#{1,3} (.+)$/gm, '\\n$1\\n' + '-'.repeat(30))\n  .replace(/\\*\\*(.+?)\\*\\*/g, '$1')\n  .replace(/^---+$/gm, '-'.repeat(30))\n  .trim();\n\nreturn [{\n  json: {\n    date: formData.date,\n    shift_type: formData.shift_type,\n    staffing_json: formData.staffingJson,\n    sales_json: formData.salesJson,\n    raw_notes: formData.shift_narrative,\n    ai_formatted_entry: aiText,\n    action_items: extractSection(aiText, 'Action Items for Next Shift'),\n    follow_ups: extractSection(aiText, 'Follow-ups for Management'),\n    created_at: new Date().toISOString(),\n    slackFormatted: toSlack(aiText),\n    emailSubject: `Logbook Entry — ${formData.shift_type} Shift | ${formData.date}`,\n    emailBody: toPlainText(aiText)\n  }\n}];"
      },
